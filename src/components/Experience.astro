---
const jobs = [
  {
    role:     { es: 'Desarrollador Full Stack & Automatización', en: 'Full Stack Developer & Automation' },
    subtitle: { es: 'Desarrollo web • Automatización • Data • Cloud', en: 'Web Dev • Automation • Data • Cloud' },
    company:  'El Derecho Para Todos',
    period:   { es: '06/2025 — Presente', en: '06/2025 — Present' },
    desc: {
      es: 'Diseñé y desarrollé plataformas web, automatizaciones y herramientas internas para optimizar procesos operativos y mejorar la experiencia digital de usuarios y clientes.',
      en: 'Designed and developed web platforms, automations and internal tools to optimize operational processes and improve the digital experience for users and clients.',
    },
    bullets: {
      es: [
        'Desarrollo full stack de plataformas web internas y externas.',
        'Automatización de procesos administrativos y operativos.',
        'Creación de paneles, formularios y herramientas internas.',
        'Integración y despliegue de soluciones cloud.',
      ],
      en: [
        'Full stack development of internal and external web platforms.',
        'Administrative and operational process automation.',
        'Internal dashboards, forms and tools.',
        'Cloud integration and deployment.',
      ],
    },
    tags:     ['Python', 'React', 'Node.js', 'PostgreSQL', 'JavaScript'],
    color:    'var(--cyan)',
    colorHex: '#22d3ee',
  },
  {
    role:     { es: 'Desarrollo Digital — Campaña Política', en: 'Digital Development — Political Campaign' },
    subtitle: { es: 'Full Stack • Landing Pages • Automatización', en: 'Full Stack • Landing Pages • Automation' },
    company:  'Proyecto interno / Consultoría digital',
    period:   { es: '2025', en: '2025' },
    desc: {
      es: 'Desarrollé soluciones digitales para campañas de comunicación política con alcance nacional.',
      en: 'Developed digital solutions for political communication campaigns with national reach.',
    },
    bullets: {
      es: [
        'Desarrollo de sitios web y landing pages.',
        'Formularios y sistemas de captura de datos a escala nacional.',
        'Automatización de procesos de registro y seguimiento.',
        'Despliegue y soporte técnico de herramientas digitales.',
      ],
      en: [
        'Websites and landing pages development.',
        'Data capture forms and systems at national scale.',
        'Registration and tracking process automation.',
        'Deployment and technical support of digital tools.',
      ],
    },
    tags:     ['React', 'Next.js', 'Node.js', 'Google Sheets API'],
    color:    'var(--cyan)',
    colorHex: '#22d3ee',
  },
  {
    role:     { es: 'Practicante de Soporte TI', en: 'IT Support Intern' },
    subtitle: { es: 'Soporte TI • Gestión de Incidentes • SAP', en: 'IT Support • Incident Management • SAP' },
    company:  'Algar Tech — SAP SURA',
    period:   { es: '2023', en: '2023' },
    desc: {
      es: 'Apoyé procesos de soporte técnico en entorno corporativo, atendiendo incidentes de plataformas empresariales.',
      en: 'Supported technical support processes in a corporate environment, handling enterprise platform incidents.',
    },
    bullets: {
      es: [
        'Gestión y seguimiento de tickets de soporte.',
        'Resolución de incidencias y acompañamiento a usuarios.',
        'Documentación y escalamiento de problemas técnicos.',
        'Trabajo colaborativo con equipos empresariales.',
      ],
      en: [
        'Support ticket management and tracking.',
        'Incident resolution and user support.',
        'Technical problem documentation and escalation.',
        'Collaborative work with enterprise teams.',
      ],
    },
    tags:     ['SAP', 'Service Desk', 'Soporte TI', 'Trello'],
    color:    'var(--cyan)',
    colorHex: '#22d3ee',
  },
  {
    role:     { es: 'Freelancer Full Stack', en: 'Full Stack Freelancer' },
    subtitle: { es: 'Full Stack • Automatización • APIs • Clientes reales', en: 'Full Stack • Automation • APIs • Real clients' },
    company:  'Proyectos independientes',
    period:   { es: '2022 — Presente', en: '2022 — Present' },
    desc: {
      es: 'Desarrollo de soluciones web y automatizaciones para pequeñas empresas, estudiantes y clientes independientes.',
      en: 'Web solutions and automations for small businesses, students and independent clients.',
    },
    bullets: {
      es: [
        'Páginas web y plataformas personalizadas.',
        'Automatización de procesos y generación de reportes.',
        'Integración de APIs y bases de datos.',
        'Dashboards y herramientas administrativas.',
      ],
      en: [
        'Custom websites and platforms.',
        'Process automation and report generation.',
        'API and database integration.',
        'Dashboards and admin tools.',
      ],
    },
    tags:     ['Python', 'Django', 'React', 'Node.js', 'MySQL'],
    color:    'var(--cyan)',
    colorHex: '#22d3ee',
  },
];
---

<section id="experience">
  <div class="container">
    <div style="text-align: center; margin-bottom: 60px;" class="reveal">
      <p class="section-label">
        <span class="es-only">// dónde he estado</span>
        <span class="en-only">// where I've been</span>
      </p>
      <h2 class="section-title">
        <span class="es-only">Experiencia</span>
        <span class="en-only">Experience</span>
      </h2>
    </div>

    <div class="timeline">
      <div class="timeline-line"></div>

      {jobs.map((job, i) => (
        <div class="timeline-row reveal">
          <!-- Left side -->
          <div class={`tl-left ${i % 2 === 0 ? 'tl-has-card' : 'tl-has-date'}`}>
            {i % 2 === 0 ? (
              <div class="exp-card sketch-card" data-color={job.colorHex}>
                <div class="exp-accent" style={`background: ${job.color};`}></div>
                <div class="exp-body">
                  <h3 class="exp-role">
                    <span class="es-only">{job.role.es}</span>
                    <span class="en-only">{job.role.en}</span>
                  </h3>
                  <p class="exp-subtitle">
                    <span class="es-only">{job.subtitle.es}</span>
                    <span class="en-only">{job.subtitle.en}</span>
                  </p>
                  <p class="exp-company" style={`color: ${job.color};`}>{job.company}</p>
                  <p class="exp-desc">
                    <span class="es-only">{job.desc.es}</span>
                    <span class="en-only">{job.desc.en}</span>
                  </p>
                  <ul class="exp-bullets">
                    {job.bullets.es.map((b, bi) => (
                      <li>
                        <span class="es-only">{b}</span>
                        <span class="en-only">{job.bullets.en[bi]}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="exp-tags">
                    {job.tags.map((t) => <span class="exp-tag">{t}</span>)}
                  </div>
                </div>
              </div>
            ) : (
              <span class="tl-date">
                <span class="es-only">{job.period.es}</span>
                <span class="en-only">{job.period.en}</span>
              </span>
            )}
          </div>

          <!-- Center dot -->
          <div class="tl-center">
            <div class="tl-dot" style={`background: ${job.color}; box-shadow: 0 0 12px ${job.colorHex}, 0 0 24px ${job.colorHex}40;`}></div>
          </div>

          <!-- Right side -->
          <div class={`tl-right ${i % 2 !== 0 ? 'tl-has-card' : 'tl-has-date'}`}>
            {i % 2 !== 0 ? (
              <div class="exp-card sketch-card" data-color={job.colorHex}>
                <div class="exp-accent" style={`background: ${job.color};`}></div>
                <div class="exp-body">
                  <h3 class="exp-role">
                    <span class="es-only">{job.role.es}</span>
                    <span class="en-only">{job.role.en}</span>
                  </h3>
                  <p class="exp-subtitle">
                    <span class="es-only">{job.subtitle.es}</span>
                    <span class="en-only">{job.subtitle.en}</span>
                  </p>
                  <p class="exp-company" style={`color: ${job.color};`}>{job.company}</p>
                  <p class="exp-desc">
                    <span class="es-only">{job.desc.es}</span>
                    <span class="en-only">{job.desc.en}</span>
                  </p>
                  <ul class="exp-bullets">
                    {job.bullets.es.map((b, bi) => (
                      <li>
                        <span class="es-only">{b}</span>
                        <span class="en-only">{job.bullets.en[bi]}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="exp-tags">
                    {job.tags.map((t) => <span class="exp-tag">{t}</span>)}
                  </div>
                </div>
              </div>
            ) : (
              <span class="tl-date">
                <span class="es-only">{job.period.es}</span>
                <span class="en-only">{job.period.en}</span>
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline { position: relative; display: flex; flex-direction: column; gap: 40px; }
  .timeline-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 2px; background: linear-gradient(180deg, transparent, var(--purple), var(--cyan), transparent); transform: translateX(-50%); opacity: 0.4; }
  .timeline-row { display: grid; grid-template-columns: 1fr 48px 1fr; align-items: center; }
  .tl-left  { padding-right: 32px; text-align: right; }
  .tl-right { padding-left: 32px; }
  .tl-center { display: flex; justify-content: center; align-items: center; }
  .tl-dot  { width: 16px; height: 16px; border-radius: 50%; border: 3px solid var(--bg2); flex-shrink: 0; }
  .tl-date { color: var(--text-dim); font-family: var(--font-art); font-size: 1rem; }
  .exp-card { padding: 24px; text-align: left; transition: all 0.3s ease !important; }
  .exp-card:hover { transform: translateY(-6px) !important; box-shadow: 0 16px 50px rgba(0,0,0,0.4) !important; }
  .exp-accent { position: absolute; top: 0; left: 0; width: 3px; height: 100%; border-radius: 16px 0 0 16px; opacity: 0.8; }
  .exp-body { padding-left: 8px; }
  .exp-role { font-family: var(--font-art); font-size: 1.3rem; font-weight: 700; color: var(--text); margin-bottom: 2px; }
  .exp-subtitle { font-size: 0.78rem; color: var(--text-dim); letter-spacing: 0.03em; margin-bottom: 6px; }
  .exp-company { font-weight: 600; font-size: 0.9rem; margin-bottom: 10px; }
  .exp-desc { color: var(--text-muted); font-size: 0.9rem; line-height: 1.7; margin-bottom: 8px; }
  .exp-bullets { list-style: none; padding: 0; margin: 0 0 14px 0; display: flex; flex-direction: column; gap: 4px; }
  .exp-bullets li { color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; padding-left: 14px; position: relative; }
  .exp-bullets li::before { content: '▸'; position: absolute; left: 0; opacity: 0.5; font-size: 0.75rem; top: 2px; }
  .exp-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .exp-tag { padding: 3px 10px; border-radius: 50px; font-size: 0.75rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--text-muted); }
  @media (max-width: 768px) {
    .timeline-line { left: 16px; }
    .timeline-row  { grid-template-columns: 32px 1fr; }
    .tl-left       { display: none; }
    .tl-right      { padding-left: 16px; grid-column: 2; }
    .tl-center     { justify-content: flex-start; }
  }
</style>
